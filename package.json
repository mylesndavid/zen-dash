{
  "name": "zen-dash",
  "version": "1.0.0",
  "description": "Zen productivity dashboard - Pomodoro, Time Blocks, Tasks",
  "main": "electron.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build",
    "package": "vite build && electron-builder --mac",
    "package:all": "vite build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.zendash.app",
    "productName": "Zen Dash",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.cjs",
      "trayTemplate@2x.png",
      "src/main/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
